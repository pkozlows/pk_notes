@article{Caruso_2016a,
	abstract = {We study the spectral function of the homogeneous electron gas using many-body perturbation theory and the cumulant expansion. We compute the angle-resolved spectral function based on the GW approximation and the ``GW plus cumulant'' approach. In agreement with previous studies, the GW spectral function exhibits a spurious plasmaron peak at energies 1.5{$\omega$}pl below the quasiparticle peak, {$\omega$}pl being the plasma energy. The GW plus cumulant approach, on the other hand, reduces significantly the intensity of the plasmon-induced spectral features and renormalizes their energy relative to the quasiparticle energy to {$\omega$}pl. Consistently with previous work on semiconductors, our results show that the HEG is characterized by the emergence of plasmonic polaron bands, that is, broadened replica of the quasiparticle bands, red-shifted by the plasmon energy.},
	author = {Caruso, Fabio and Giustino, Feliciano},
	date-added = {2024-01-24 23:34:13 +0100},
	date-modified = {2025-07-22 15:47:27 +0200},
	doi = {10.1140/epjb/e2016-70028-4},
	file = {/Users/loos/Zotero/storage/ZBR7QCZN/Caruso and Giustino - 2016 - The GW plus cumulant method and plasmonic polarons.pdf},
	issn = {1434-6028, 1434-6036},
	journal = {Eur. Phys. J. B},
	month = nov,
	number = {11},
	pages = {238},
	shorttitle = {The {{GW}} plus Cumulant Method and Plasmonic Polarons},
	title = {The {{GW}} plus Cumulant Method and Plasmonic Polarons: Application to the Homogeneous Electron Gas*},
	urldate = {2024-01-19},
	volume = {89},
	year = {2016},
	bdsk-url-1 = {https://doi.org/10.1140/epjb/e2016-70028-4}}

