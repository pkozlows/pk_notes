@ARTICLE{Schimka2010-re,
  title     = "Accurate surface and adsorption energies from many-body
               perturbation theory",
  author    = "Schimka, L and Harl, J and Stroppa, A and Grüneis, A and Marsman,
               M and Mittendorfer, F and Kresse, G",
  journal   = "Nat. Mater.",
  publisher = "Springer Science and Business Media LLC",
  volume    =  9,
  number    =  9,
  pages     = "741--744",
  abstract  = "Kohn-Sham density functional theory is the workhorse
               computational method in materials and surface science.
               Unfortunately, most semilocal density functionals predict
               surfaces to be more stable than they are experimentally. Naively,
               we would expect that consequently adsorption energies on surfaces
               are too small as well, but the contrary is often found:
               chemisorption energies are usually overestimated. Modifying the
               functional improves either the adsorption energy or the surface
               energy but always worsens the other aspect. This suggests that
               semilocal density functionals possess a fundamental flaw that is
               difficult to cure, and alternative methods are urgently needed.
               Here we show that a computationally fairly efficient
               many-electron approach, the random phase approximation to the
               correlation energy, resolves this dilemma and yields at the same
               time excellent lattice constants, surface energies and adsorption
               energies for carbon monoxide and benzene on transition-metal
               surfaces.",
  month     =  sep,
  year      =  2010,
  language  = "en"
}

